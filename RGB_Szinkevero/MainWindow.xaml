<Window x:Class="RGB_Szinkevero.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RGB_Szinkevero"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="RGB Színkeverő" FontSize="30" FontWeight="Bold"/>

            <TextBlock Text="Red" Margin="0,15,0,0" FontSize="18"/>
            <Slider Name="RedSlider" Minimum="0" Maximum="255" VerticalAlignment="Center" Margin="10" ValueChanged="ColorChange"/>

            <TextBlock Text="Green" Margin="0,15,0,0" FontSize="18"/>
            <Slider Name="GreenSlider" Minimum="0" Maximum="255" VerticalAlignment="Center" Margin="10" ValueChanged="ColorChange"/>

            <TextBlock Text="Blue" Margin="0,15,0,0" FontSize="18"/>
            <Slider Name="BlueSlider" Minimum="0" Maximum="255" VerticalAlignment="Center" Margin="10" ValueChanged="ColorChange"/>

            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                <CheckBox x:Name="RedCheckBox" Content="Piros zárás" Margin="10" IsChecked="False"/>
                <CheckBox x:Name="GreenCheckBox" Content="Zöld zárás" Margin="10" IsChecked="False"/>
                <CheckBox x:Name="BlueCheckBox" Content="Kék zárás" Margin="10" IsChecked="False"/>
            </StackPanel>

            <Rectangle Name="ColorPreview" Width="250" Height="120" Margin="10">
                <Rectangle.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </Rectangle.Effect>
            </Rectangle>
            <TextBlock x:Name="txtPreviewLabel" Text="Előnézet" Foreground="Black" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,-90,0,50" IsHitTestVisible="False"/>

            <TextBlock x:Name="txtRGB" Text="RGB: (0, 0, 0)" FontSize="18" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtHex" Text="HEX: #000000" FontSize="18" HorizontalAlignment="Center" Margin="10"/>

            <Button Name="btnRandom" Content="Random szín" Width="120" Height="30" Margin="10" HorizontalAlignment="Center" Click="btnRandom_Click"/>
            <Button Name="btnReset" Content="Szín alaphelyzet" Width="120" Height="30" Margin="10" HorizontalAlignment="Center" Click="btnReset_Click"/>
            <Button Name="btnCanvasDelete" Content="Canvas törlése" Width="120" Height="30" Margin="10" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
